<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <title>724财讯</title>
    <link rel="icon" type="image/svg+xml" href="favicon.svg">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.bootcdn.net/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.bootcdn.net/ajax/libs/socket.io/4.6.1/socket.io.min.js"></script>
    <script src="https://cdn.bootcdn.net/ajax/libs/marked/4.3.0/marked.min.js"></script>

    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: '#3B82F6',
                        secondary: '#10B981',
                        dark: {
                            bg: '#0F172A',
                            surface: '#1E293B',
                            border: '#334155'
                        }
                    }
                }
            }
        }
    </script>

    <style>
        * { -webkit-tap-highlight-color: transparent; }
        body { overscroll-behavior: none; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
        .safe-top { padding-top: env(safe-area-inset-top, 0px); }
        .safe-bottom { padding-bottom: env(safe-area-inset-bottom, 16px); }

        .message-item { animation: slideIn 0.3s ease-out; }
        @keyframes slideIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        .spinner { border: 3px solid #f3f3f3; border-top: 3px solid #3B82F6; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

        .touch-feedback { transition: all 0.15s ease; }
        .touch-feedback:active { transform: scale(0.95); opacity: 0.8; }

        .channel-active { border-left: 3px solid #3B82F6; background: #eff6ff; }
        .dark .channel-active { background: #1e3a8a; }

        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

        .tab-btn.active { color: #3B82F6; border-bottom: 2px solid #3B82F6; }

        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 2px; }
        .dark ::-webkit-scrollbar-thumb { background: #475569; }
    </style>
</head>
<body class="bg-gray-50 dark:bg-dark-bg text-gray-900 dark:text-gray-100 h-screen flex flex-col overflow-hidden">

    <!-- 顶部 AppBar -->
    <header class="flex-shrink-0 safe-top">
        <div class="h-14 bg-white dark:bg-dark-surface border-b border-gray-200 dark:border-dark-border flex items-center justify-between px-4">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center">
                    <i class="fas fa-bolt text-white text-sm"></i>
                </div>
                <span class="font-bold text-lg">724财讯</span>
            </div>

            <div class="flex items-center gap-2">
                <!-- 盘面按钮 -->
                <button onclick="showDashboard()" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 touch-feedback">
                    <i class="fas fa-chart-line text-blue-500"></i>
                </button>
                <!-- 主题切换 -->
                <button onclick="toggleTheme()" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 touch-feedback">
                    <i class="fas fa-moon dark:hidden"></i>
                    <i class="fas fa-sun hidden dark:inline"></i>
                </button>
                <!-- 登录/设置 -->
                <div id="authContainer">
                    <button id="loginBtn" onclick="window.location.href='auth_m.html'" class="px-3 py-1.5 bg-gradient-to-r from-blue-500 to-indigo-600 text-white text-sm rounded-lg">
                        登录
                    </button>
                    <button id="userBtn" onclick="showSettings()" class="hidden p-2">
                        <i class="fas fa-user-circle text-2xl text-gray-600 dark:text-gray-400"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- WebSocket状态栏 -->
        <div class="h-8 bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-gray-800 dark:to-gray-800 flex items-center justify-between px-4 text-xs">
            <div class="flex items-center gap-2">
                <div id="wsStatusDot" class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></div>
                <span id="wsStatusText" class="text-gray-600 dark:text-gray-400">离线</span>
            </div>
            <div id="currentTime" class="text-gray-500"></div>
        </div>
    </header>

    <!-- 主内容区域 -->
    <main id="mainView" class="flex-1 overflow-hidden relative">
        <!-- 消息视图 (默认显示) -->
        <div id="messagesView" class="h-full flex flex-col">
            <!-- 频道信息栏 - 可点击展开频道列表 -->
            <div onclick="showChannelList()" class="flex-shrink-0 px-4 py-3 bg-white dark:bg-dark-surface border-b border-gray-200 dark:border-dark-border cursor-pointer touch-feedback">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2 flex-1 min-w-0">
                        <i class="fas fa-comments text-blue-500 flex-shrink-0"></i>
                        <h2 id="currentChannelName" class="font-semibold truncate">请选择频道</h2>
                    </div>
                    <div class="flex items-center gap-2">
                        <span id="currentTabLabel" class="px-2 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 text-xs rounded">公开</span>
                        <i class="fas fa-chevron-down text-gray-400"></i>
                    </div>
                </div>
            </div>

            <!-- 消息列表 -->
            <div id="messageContainer" class="flex-1 overflow-y-auto hide-scrollbar p-4 space-y-3">
                <div class="flex items-center justify-center h-full text-gray-400">
                    <div class="text-center">
                        <i class="fas fa-comment-dots text-6xl mb-4"></i>
                        <p>点击上方选择频道开始查看消息</p>
                    </div>
                </div>
            </div>

            <!-- 总结面板 - 可展开 -->
            <div id="summaryPanel" class="hidden flex-shrink-0 bg-white dark:bg-dark-surface border-t border-gray-200 dark:border-dark-border">
                <div class="p-3 border-b border-gray-200 dark:border-dark-border flex items-center justify-between cursor-pointer" onclick="toggleSummary()">
                    <h3 class="font-semibold flex items-center gap-2">
                        <i class="fas fa-clipboard-list text-blue-500"></i>
                        当日总结
                    </h3>
                    <i id="summaryArrow" class="fas fa-chevron-up transition-transform"></i>
                </div>
                <div id="summaryContent" class="p-4 max-h-60 overflow-y-auto">
                    <div class="text-gray-400 text-sm text-center py-8">
                        <i class="fas fa-info-circle mb-2"></i>
                        <p>选择消息后显示总结</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- 频道列表视图 (全屏) -->
        <div id="channelListView" class="h-full overflow-y-auto hide-scrollbar hidden bg-white dark:bg-dark-surface">
            <!-- 顶部操作栏 -->
            <div class="sticky top-0 bg-white dark:bg-dark-surface z-10 safe-top">
                <!-- 切换按钮组 -->
                <div class="p-3 border-b border-gray-200 dark:border-dark-border">
                    <div class="flex gap-2">
                        <button onclick="switchTab('private')" id="tab-private" class="tab-switch flex-1 py-2.5 px-4 rounded-lg text-sm font-semibold transition-all shadow-sm hover:bg-gray-100 dark:hover:bg-gray-700">
                            <i class="fas fa-user mr-1.5"></i>私人订阅
                        </button>
                        <button onclick="switchTab('public')" id="tab-public" class="tab-switch flex-1 py-2.5 px-4 rounded-lg text-sm font-semibold transition-all shadow-sm bg-blue-500 text-white">
                            <i class="fas fa-globe mr-1.5"></i>公开消息
                        </button>
                    </div>
                </div>

                <!-- 搜索框 -->
                <div class="p-3 border-b border-gray-200 dark:border-dark-border">
                    <div class="relative">
                        <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                        <input type="text" id="searchInput" placeholder="搜索频道..." class="w-full pl-10 pr-4 py-2.5 bg-gray-100 dark:bg-gray-800 border-none rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none transition-all" oninput="handleSearch(this.value)">
                    </div>
                </div>

                <!-- 新增授权按钮 -->
                <div class="p-3 border-b border-gray-200 dark:border-dark-border">
                    <button onclick="showAuthModal()" class="w-full py-2.5 bg-gradient-to-r from-blue-500 to-indigo-600 hover:from-blue-600 hover:to-indigo-700 text-white rounded-lg font-medium transition-all flex items-center justify-center gap-2 shadow-lg touch-feedback">
                        <i class="fas fa-plus-circle"></i>
                        新增授权
                    </button>
                </div>

                <!-- 标签选择器 -->
                <div class="px-3 py-2 border-b border-gray-200 dark:border-dark-border">
                    <button onclick="toggleCategoryMenu()" class="w-full px-3 py-2.5 rounded-lg text-sm font-medium transition-all bg-gray-100 hover:bg-gray-200 dark:bg-gray-800 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300 flex items-center justify-between">
                        <span id="currentCategoryLabel">全部</span>
                        <i class="fas fa-chevron-down text-xs"></i>
                    </button>

                    <!-- 标签下拉菜单 -->
                    <div id="categoryMenu" class="hidden mt-2 bg-white dark:bg-gray-800 rounded-xl shadow-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                        <div class="p-2">
                            <button onclick="switchCategory('all')" class="w-full px-3 py-2.5 rounded-lg text-sm font-medium text-left hover:bg-gray-100 dark:hover:bg-gray-700 mb-1">全部</button>
                            <div class="h-px bg-gray-200 dark:bg-gray-700 my-2"></div>
                            <div id="categoryMenuList" class="grid grid-cols-2 gap-1"></div>
                        </div>
                    </div>
                </div>

                <!-- 关闭按钮 -->
                <div class="p-3 flex justify-center">
                    <button onclick="hideChannelList()" class="px-6 py-2 bg-gray-100 dark:bg-gray-800 rounded-lg text-sm touch-feedback">
                        <i class="fas fa-times mr-2"></i>关闭
                    </button>
                </div>
            </div>

            <!-- 频道列表 -->
            <div id="channelList" class="p-3 space-y-2 pb-20">
                <div class="flex items-center justify-center h-full">
                    <div class="spinner"></div>
                </div>
            </div>
        </div>

        <!-- 盘面视图 -->
        <div id="dashboardView" class="h-full overflow-y-auto hide-scrollbar hidden bg-gray-50 dark:bg-dark-bg">
            <div class="p-4 space-y-4">
                <!-- 操作排行 -->
                <div class="bg-white dark:bg-dark-surface rounded-xl shadow-sm overflow-hidden">
                    <div class="p-4 border-b border-gray-200 dark:border-dark-border">
                        <h3 class="font-semibold flex items-center gap-2">
                            <i class="fas fa-trophy text-yellow-500"></i>
                            操作排行
                        </h3>
                    </div>
                    <div class="p-4 space-y-3">
                        <!-- 第1名 -->
                        <div class="flex items-center gap-3 p-4 bg-gradient-to-r from-yellow-50 via-yellow-100 to-yellow-50 dark:from-yellow-900/30 dark:via-yellow-800/40 dark:to-yellow-900/30 rounded-xl border-2 border-yellow-400 shadow-lg">
                            <div class="w-12 h-12 bg-gradient-to-br from-yellow-400 to-yellow-600 text-white rounded-xl flex items-center justify-center font-black text-xl shadow-lg">1</div>
                            <div class="flex-1">
                                <p class="font-bold text-lg">张三老师</p>
                                <p class="text-sm text-red-500 font-black"><i class="fas fa-fire mr-1"></i>胜率 87%</p>
                            </div>
                            <div class="text-right">
                                <i class="fas fa-crown text-yellow-500 text-3xl"></i>
                                <p class="text-xs text-yellow-600 font-bold mt-1">冠军</p>
                            </div>
                        </div>
                        <!-- 第2名 -->
                        <div class="flex items-center gap-3 p-3 bg-gradient-to-r from-gray-50 to-gray-100 dark:from-gray-800 dark:to-gray-700 rounded-xl border border-gray-300 shadow-md">
                            <span class="w-10 h-10 bg-gradient-to-br from-gray-400 to-gray-600 text-white rounded-xl flex items-center justify-center font-black text-lg">2</span>
                            <div class="flex-1">
                                <p class="font-semibold">李四老师</p>
                                <p class="text-xs text-red-500 font-bold"><i class="fas fa-chart-line mr-1"></i>胜率 82%</p>
                            </div>
                            <div class="text-right">
                                <i class="fas fa-medal text-gray-400 text-2xl"></i>
                                <p class="text-xs text-gray-500 font-medium mt-1">亚军</p>
                            </div>
                        </div>
                        <!-- 第3名 -->
                        <div class="flex items-center gap-3 p-3 bg-gradient-to-r from-orange-50 to-orange-100 dark:from-orange-900/20 dark:to-orange-800/30 rounded-xl border border-orange-300 shadow-md">
                            <span class="w-10 h-10 bg-gradient-to-br from-orange-400 to-orange-600 text-white rounded-xl flex items-center justify-center font-black text-lg">3</span>
                            <div class="flex-1">
                                <p class="font-semibold">王五老师</p>
                                <p class="text-xs text-red-500 font-bold"><i class="fas fa-arrow-trend-up mr-1"></i>胜率 79%</p>
                            </div>
                            <div class="text-right">
                                <i class="fas fa-award text-orange-500 text-2xl"></i>
                                <p class="text-xs text-orange-600 font-medium mt-1">季军</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 待开发提示 -->
                <div class="flex flex-col items-center justify-center py-12 text-center">
                    <div class="w-24 h-24 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-full flex items-center justify-center shadow-2xl mb-6">
                        <i class="fas fa-chart-line text-white text-4xl"></i>
                    </div>
                    <h2 class="text-2xl font-bold mb-3 bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent">更多功能开发中</h2>
                    <p class="text-gray-600 dark:text-gray-400">实时行情、智能分析等功能敬请期待...</p>
                </div>
            </div>
        </div>
    </main>

    <!-- 授权弹窗 -->
    <div id="authModal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4">
        <div class="bg-white dark:bg-dark-surface rounded-xl shadow-2xl w-full max-w-lg overflow-hidden">
            <div class="p-4 border-b border-gray-200 dark:border-dark-border flex justify-between items-center">
                <h3 class="font-semibold text-lg">新增授权</h3>
                <button onclick="closeAuthModal()" class="p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg touch-feedback">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <div class="flex border-b border-gray-200 dark:border-dark-border">
                <button onclick="switchAuthTab('card')" id="cardTabBtn" class="flex-1 py-3 px-4 text-sm font-medium border-b-2 border-blue-500 text-blue-600">
                    <i class="fas fa-ticket-alt mr-2"></i>卡密兑换
                </button>
                <button onclick="switchAuthTab('subscribe')" id="subscribeTabBtn" class="flex-1 py-3 px-4 text-sm font-medium border-b-2 border-transparent hover:bg-gray-50 dark:hover:bg-gray-800">
                    <i class="fas fa-list mr-2"></i>订阅频道
                </button>
            </div>

            <div class="p-4 max-h-[70vh] overflow-y-auto">
                <!-- 卡密兑换 -->
                <div id="cardTabContent" class="space-y-4">
                    <div id="cardStep1">
                        <label class="block text-sm font-medium mb-2">输入卡密</label>
                        <div class="flex gap-2">
                            <input type="text" id="cardCodeInput" placeholder="请输入卡密代码" class="flex-1 px-4 py-2.5 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none bg-transparent font-mono text-sm">
                            <button onclick="verifyCard()" class="px-4 py-2.5 bg-gradient-to-r from-blue-500 to-indigo-600 text-white rounded-lg touch-feedback">验证</button>
                        </div>
                        <p class="text-xs text-gray-500 mt-2"><i class="fas fa-info-circle mr-1"></i>卡密格式：CARD-XXXXXXXXXXXXXXXX</p>
                    </div>

                    <div id="cardStep2" class="hidden space-y-4">
                        <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg p-4">
                            <h4 class="font-medium mb-2">卡密信息</h4>
                            <div class="text-sm space-y-1">
                                <p><span class="text-gray-500">模板:</span> <span id="cardTemplateName">-</span></p>
                                <p><span class="text-gray-500">有效期:</span> <span id="cardValidityDays">-</span> 天</p>
                                <p><span class="text-gray-500">可选:</span> 最多 <span id="cardMaxChannels">-</span> 个频道</p>
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium mb-2">选择订阅频道 <span class="text-gray-500 text-xs">(已选 <span id="selectedCount">0</span>/<span id="maxCount">-</span>)</span></label>
                            <div id="cardChannelSelector" class="space-y-2 max-h-60 overflow-y-auto border border-gray-200 dark:border-gray-600 rounded-lg p-3">
                                <div class="text-center text-gray-500 py-4"><i class="fas fa-spinner fa-spin mr-2"></i>加载中...</div>
                            </div>
                        </div>

                        <button onclick="confirmCardSubscribe()" class="w-full py-3 bg-gradient-to-r from-blue-500 to-indigo-600 text-white rounded-lg font-medium touch-feedback">
                            <i class="fas fa-check mr-2"></i>确认订阅
                        </button>
                    </div>
                </div>

                <!-- 订阅频道 -->
                <div id="subscribeTabContent" class="hidden space-y-4">
                    <div id="subscribeChannelSelector" class="space-y-2 max-h-96 overflow-y-auto">
                        <div class="text-center text-gray-500 py-4"><i class="fas fa-spinner fa-spin mr-2"></i>加载中...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 设置弹窗 -->
    <div id="settingsModal" class="fixed inset-0 bg-black/50 z-50 hidden">
        <div class="absolute bottom-0 left-0 right-0 bg-white dark:bg-dark-surface rounded-t-3xl max-h-[80vh] overflow-y-auto safe-bottom">
            <div class="sticky top-0 bg-white dark:bg-dark-surface px-4 py-4 border-b border-gray-200 dark:border-dark-border flex items-center justify-between">
                <h3 class="font-semibold text-lg">设置</h3>
                <button onclick="hideSettings()" class="p-2 -mr-2 touch-feedback">
                    <i class="fas fa-times text-gray-500"></i>
                </button>
            </div>
            <div class="px-4 py-4 space-y-4">
                <div class="flex items-center justify-between py-3 border-b border-gray-100 dark:border-gray-700">
                    <span>深色模式</span>
                    <button onclick="toggleTheme(); hideSettings();" class="w-12 h-7 bg-gray-300 dark:bg-blue-600 rounded-full relative transition-colors">
                        <div class="absolute top-1 left-1 dark:left-6 w-5 h-5 bg-white rounded-full shadow transition-all"></div>
                    </button>
                </div>
                <div id="userInfoSection" class="hidden py-3 border-b border-gray-100 dark:border-gray-700">
                    <p id="userNickname" class="font-semibold mb-3"></p>
                    <button onclick="handleLogout(); hideSettings();" class="w-full py-2.5 bg-red-50 dark:bg-red-900/30 text-red-600 dark:text-red-400 rounded-lg touch-feedback">
                        退出登录
                    </button>
                </div>
                <div class="py-3 text-center text-sm text-gray-500">
                    <p>724财讯 v1.0.0</p>
                    <p class="text-xs mt-1">实时财经资讯推送平台</p>
                </div>
            </div>
        </div>
    </div>

    <script src="config.js"></script>
    <script>
        // 全局变量（桌面版对应）
        let socket = null;
        let currentChannel = null;
        let currentTab = 'public'; // 'private' or 'public'
        let currentCategory = 'all'; // 当前选中的分类
        let isDarkMode = false;
        let isLoggedIn = false;

        // 获取用户信息（从localStorage）
        function getUser() {
            const userStr = localStorage.getItem('user');
            return userStr ? JSON.parse(userStr) : null;
        }

        // 真实数据
        let allChannels = [];  // 所有频道
        let unreadCounts = {};  // 未读数映射
        let allCategories = [];  // 所有标签（从API加载）
        let categoriesCache = {
            public: null,
            private: null
        };  // 标签缓存（懒加载）
        let channelLatestMessage = {};  // 每个频道的最新消息
        let channelLatestTime = {};  // 每个频道的最新消息时间
        let channelMessageOffset = {};  // 每个频道已加载的消息数量（用于分页）
        let channelMessageTotal = {};  // 每个频道的总消息数
        let isLoadingMore = false;  // 是否正在加载更多消息
        let channelMessagesCache = {};  // 频道消息缓存 {channelId: {messages: [], offset: 0, total: 0}}
        let loadedChannels = new Set();  // 已加载过的频道ID集合

        // Token刷新状态（防止并发刷新）
        let isRefreshing = false;
        let refreshSubscribers = [];

        // 添加等待刷新完成的订阅者
        function subscribeTokenRefresh(callback) {
            refreshSubscribers.push(callback);
        }

        // 通知所有订阅者token已刷新
        function onRefreshed(newToken) {
            refreshSubscribers.forEach(callback => callback(newToken));
            refreshSubscribers = [];
        }

        // 初始化应用
        async function init() {
            // 更新认证按钮显示
            updateAuthButton();

            initTheme();
            updateTime();
            setInterval(updateTime, 1000);

            // 初始化 WebSocket 状态为离线
            updateWSStatus(false);

            // 如果有token，检查登录状态
            if (currentToken) {
                await checkAuth();
            }

            await loadChannels();
            renderChannelList();

            connectWebSocket();
            startChannelsRefresh();
        }

        document.addEventListener('DOMContentLoaded', () => {
            init();
        });

        function updateTime() {
            const now = new Date();
            document.getElementById('currentTime').textContent = now.toLocaleString('zh-CN', {
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit'
            });
        }

        function connectWebSocket() {
            socket = io(WS_URL, { transports: ['websocket'], reconnection: true });

            socket.on('connect', () => {
                updateWSStatus(true);
                if (currentToken) {
                    socket.emit('authenticate', { token: currentToken });
                }
                loadChannels();
            });

            socket.on('disconnect', () => updateWSStatus(false));

            socket.on('new_message', (data) => {
                if (!messages[data.channel_id]) messages[data.channel_id] = [];
                messages[data.channel_id].unshift(data);
                unreadCounts[data.channel_id] = (unreadCounts[data.channel_id] || 0) + 1;

                if (data.channel_id === currentChannelId) {
                    appendMessage(data);
                    socket.emit('mark_read', { channel_id: data.channel_id });
                    unreadCounts[data.channel_id] = 0;
                }

                updateMessageBadge();
                renderChannelList();
            });

            socket.on('push', (data) => appendMessage(data));
        }

        async function loadChannels() {
            try {
                const isAdmin = !currentToken;
                const response = await fetch(`${API_BASE}/api/channels${isAdmin ? '?admin=true' : ''}`);
                const data = await response.json();

                if (data.channels) {
                    allChannels = data.channels;
                    renderChannelList();
                }
            } catch (error) {
                console.error('加载频道失败:', error);
            }
        }

        function renderChannelList() {
            const container = document.getElementById('channelList');
            const filtered = allChannels.filter(ch => {
                const matchTab = currentTab === 'private' ? ch.type === 'private' : ch.type === 'public';
                const matchCategory = currentCategory === 'all' || ch.category_id == currentCategory;
                return matchTab && matchCategory;
            });

            if (filtered.length === 0) {
                container.innerHTML = `<div class="text-center py-20 text-gray-500"><i class="fas fa-inbox text-4xl mb-4"></i><p>暂无频道</p></div>`;
                return;
            }

            container.innerHTML = filtered.map(ch => `
                <div onclick="selectChannel('${ch.id}')" class="p-4 bg-gray-50 dark:bg-gray-800 rounded-xl cursor-pointer touch-feedback ${currentChannelId === ch.id ? 'channel-active' : ''}">
                    <div class="flex items-center gap-3">
                        ${ch.avatar ? `<img src="${ch.avatar}" class="w-12 h-12 rounded-lg object-cover">` : `<div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center"><i class="fas fa-bolt text-white"></i></div>`}
                        <div class="flex-1 min-w-0">
                            <h3 class="font-semibold truncate">${ch.name}</h3>
                            <p class="text-xs text-gray-500 mt-0.5">${ch.category_name || '未分类'}</p>
                        </div>
                        ${unreadCounts[ch.id] > 0 ? `<span class="flex-shrink-0 w-6 h-6 bg-red-500 text-white text-xs rounded-full flex items-center justify-center">${unreadCounts[ch.id] > 99 ? '99+' : unreadCounts[ch.id]}</span>` : ''}
                    </div>
                </div>
            `).join('');
        }

        function selectChannel(channelId) {
            currentChannelId = channelId;
            const channel = allChannels.find(ch => ch.id == channelId);

            if (channel) {
                document.getElementById('currentChannelName').textContent = channel.name;
            }

            loadMessages(channelId);
            hideChannelList();
        }

        async function loadMessages(channelId) {
            const container = document.getElementById('messageContainer');

            if (messages[channelId] && messages[channelId].length > 0) {
                renderMessages(messages[channelId]);
                return;
            }

            container.innerHTML = '<div class="flex items-center justify-center h-full"><div class="spinner"></div></div>';

            try {
                const response = await fetch(`${API_BASE}/api/ws/switch-channel`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        socket_id: currentUserId || 'guest',
                        channel_id: channelId,
                        limit: 50
                    })
                });

                const data = await response.json();

                if (data.success) {
                    messages[channelId] = data.history.reverse();
                    renderMessages(messages[channelId]);
                    unreadCounts[channelId] = 0;
                    renderChannelList();
                }
            } catch (error) {
                container.innerHTML = '<div class="text-center py-20 text-gray-500"><i class="fas fa-exclamation-circle text-4xl mb-4"></i><p>加载失败</p></div>';
            }
        }

        function renderMessages(msgs) {
            const container = document.getElementById('messageContainer');

            if (!msgs || msgs.length === 0) {
                container.innerHTML = `<div class="text-center py-20 text-gray-500"><i class="fas fa-comment-slash text-4xl mb-4"></i><p>暂无消息</p></div>`;
                return;
            }

            container.innerHTML = msgs.map(msg => createMessageHTML(msg)).join('');
            container.scrollTop = container.scrollHeight;
        }

        function createMessageHTML(msg) {
            const timestamp = msg.timestamp ? new Date(msg.timestamp).toLocaleString('zh-CN', {
                month: '2-digit',
                day: '2-digit',
                hour: '2-digit',
                minute: '2-digit'
            }) : '';

            return `
                <div class="message-item bg-white dark:bg-dark-surface rounded-xl p-4 shadow-sm border border-gray-100 dark:border-dark-border">
                    ${msg.title ? `<h4 class="font-semibold mb-2">${msg.title}</h4>` : ''}
                    <div class="prose prose-sm dark:prose-invert max-w-none text-gray-700 dark:text-gray-300">${msg.content}</div>
                    <p class="text-xs text-gray-400 mt-3">${timestamp}</p>
                </div>
            `;
        }

        function appendMessage(msg) {
            const container = document.getElementById('messageContainer');
            const loading = container.querySelector('.spinner');
            if (loading) loading.parentElement.remove();

            container.insertAdjacentHTML('afterbegin', createMessageHTML(msg));
        }

        function switchTab(tab) {
            currentTab = tab;

            document.querySelectorAll('.tab-switch').forEach(btn => {
                btn.classList.remove('bg-blue-500', 'text-white');
                if (btn.id === `tab-${tab}`) {
                    btn.classList.add('bg-blue-500', 'text-white');
                }
            });

            document.getElementById('currentTabLabel').textContent = tab === 'private' ? '私人' : '公开';
            renderChannelList();
        }

        function toggleCategoryMenu() {
            document.getElementById('categoryMenu').classList.toggle('hidden');
        }

        function switchCategory(categoryId) {
            currentCategory = categoryId;
            document.getElementById('currentCategoryLabel').textContent = categoryId === 'all' ? '全部' : `标签 ${categoryId}`;
            toggleCategoryMenu();
            renderChannelList();
        }

        function handleSearch(keyword) {
            const filtered = allChannels.filter(ch => ch.name.toLowerCase().includes(keyword.toLowerCase()));
            // 重新渲染过滤后的列表
        }

        function showChannelList() {
            document.getElementById('channelListView').classList.remove('hidden');
        }

        function hideChannelList() {
            document.getElementById('channelListView').classList.add('hidden');
        }

        function showDashboard() {
            document.getElementById('messagesView').classList.add('hidden');
            document.getElementById('channelListView').classList.add('hidden');
            document.getElementById('dashboardView').classList.remove('hidden');
        }

        function showMessages() {
            document.getElementById('dashboardView').classList.add('hidden');
            document.getElementById('messagesView').classList.remove('hidden');
        }

        function toggleSummary() {
            const content = document.getElementById('summaryContent');
            const arrow = document.getElementById('summaryArrow');
            content.classList.toggle('hidden');
            arrow.classList.toggle('rotate-180');
        }

        function showAuthModal() {
            document.getElementById('authModal').classList.remove('hidden');
            document.getElementById('authModal').classList.add('flex');
        }

        function closeAuthModal() {
            document.getElementById('authModal').classList.add('hidden');
            document.getElementById('authModal').classList.remove('flex');
        }

        function switchAuthTab(tab) {
            // 切换卡密/订阅标签页
        }

        function verifyCard() {
            // 验证卡密逻辑
        }

        function showSettings() {
            document.getElementById('settingsModal').classList.remove('hidden');
        }

        function hideSettings() {
            document.getElementById('settingsModal').classList.add('hidden');
        }

        function initTheme() {
            if (localStorage.getItem('theme') === 'dark' || (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            }
        }

        function toggleTheme() {
            const html = document.documentElement;
            if (html.classList.contains('dark')) {
                html.classList.remove('dark');
                localStorage.setItem('theme', 'light');
            } else {
                html.classList.add('dark');
                localStorage.setItem('theme', 'dark');
            }
        }

        async function checkAuth() {
            try {
                console.log('检查登录状态，token:', currentToken ? '存在' : '不存在');

                const response = await fetch(`${API_BASE}/api/auth/me`, {
                    headers: { 'Authorization': `Bearer ${currentToken}` }
                });
                const data = await response.json();

                console.log('用户信息响应:', data);

                if (data.success && data.user) {
                    currentUserId = data.user.id;
                    const nickname = data.user.nickname || data.user.email || '用户';

                    document.getElementById('loginBtn').classList.add('hidden');
                    document.getElementById('userBtn').classList.remove('hidden');
                    document.getElementById('userInfoSection').classList.remove('hidden');
                    document.getElementById('userNickname').textContent = nickname;

                    console.log('登录成功，昵称:', nickname);
                } else {
                    console.log('未登录或token无效');
                    handleLogout();
                }
            } catch (error) {
                console.error('检查登录状态失败:', error);
                handleLogout();
            }
        }

        function handleLogout() {
            localStorage.removeItem('access_token');
            localStorage.removeItem('refresh_token');
            window.location.reload();
        }

        // 更新认证按钮显示
        function updateAuthButton() {
            const loginBtn = document.getElementById('loginBtn');
            const userBtn = document.getElementById('userBtn');
            const userInfoSection = document.getElementById('userInfoSection');
            const userNickname = document.getElementById('userNickname');

            if (currentToken) {
                // 已登录状态在 checkAuth 中处理
                // 这里只处理未登录状态
                if (!currentUserId) {
                    loginBtn.classList.remove('hidden');
                    userBtn.classList.add('hidden');
                    userInfoSection.classList.add('hidden');
                }
            } else {
                // 未登录，显示登录按钮
                loginBtn.classList.remove('hidden');
                userBtn.classList.add('hidden');
                userInfoSection.classList.add('hidden');
            }
        }

        // 启动定时刷新频道信息（每5分钟）
        function startChannelsRefresh() {
            setInterval(async () => {
                await loadChannels();
                renderChannelList();
            }, 5 * 60 * 1000); // 5分钟
        }


        function updateWSStatus(connected) {
            const dot = document.getElementById('wsStatusDot');
            const text = document.getElementById('wsStatusText');

            if (connected) {
                dot.classList.remove('bg-red-500');
                dot.classList.add('bg-green-500');
                text.textContent = '在线';
            } else {
                dot.classList.remove('bg-green-500');
                dot.classList.add('bg-red-500');
                text.textContent = '离线';
            }
        }

        function updateMessageBadge() {
            // 更新消息角标
        }
    </script>
</body>
</html>
